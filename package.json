{
  "name": "ishtarkati",
  "private": true,
  "version": "1.0.10",
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "Arabic subscription tracker (Electron)",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/bump-patch-for-build.mjs && tsc && vite build && electron-builder --linux AppImage",
    "build:pack": "SKIP_VERSION_BUMP=1 tsc && vite build && electron-builder --linux AppImage",
    "watch:build": "chokidar \"src/**/*\" \"electron/**/*\" \"index.html\" \"vite.config.ts\" \"src/index.css\" -c \"npm run build:pack\" -d 2500 --initial",
    "preview": "vite preview",
    "version:bump": "node scripts/bump-version.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fontsource/tajawal": "^5.2.7",
    "better-sqlite3": "^11.10.0",
    "date-fns": "^4.1.0",
    "i18next": "^26.0.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "chokidar-cli": "^3.0.0",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.mrn.ishtarkati",
    "productName": "Ishtarkati",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office",
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}
