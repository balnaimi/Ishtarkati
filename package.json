{
  "name": "ishtarkati",
  "private": true,
  "version": "4.19.1",
  "author": "balnaimi",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "Arabic subscription tracker — desktop only (Electron; Linux AppImage, Windows x64, macOS Apple Silicon)",
  "scripts": {
    "dev": "vite",
    "rebuild:native": "npx @electron/rebuild -f -w better-sqlite3",
    "verify:native": "node scripts/verify-sqlite-electron.mjs",
    "prebuild:app": "npm run rebuild:native && npm run verify:native",
    "build": "node scripts/bump-version-for-build.mjs && npm run build:linux",
    "build:release": "npm run build && node scripts/git-ship.mjs",
    "build:pack": "npm run build:linux",
    "build:linux": "node scripts/platform-build.mjs linux",
    "build:win": "node scripts/platform-build.mjs win",
    "build:mac": "node scripts/platform-build.mjs mac",
    "ship": "node scripts/bump-version-for-build.mjs && node scripts/git-ship.mjs",
    "watch:build": "chokidar \"src/**/*\" \"electron/**/*\" \"index.html\" \"vite.config.ts\" \"src/index.css\" -c \"npm run build:pack\" -d 2500 --initial",
    "preview": "vite preview",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "posttest": "npm run rebuild:native",
    "version:bump": "node scripts/bump-version.mjs",
    "postinstall": "npm run rebuild:native"
  },
  "dependencies": {
    "@fontsource/tajawal": "^5.2.7",
    "@noble/hashes": "^2.2.0",
    "better-sqlite3": "^12.9.0",
    "date-fns": "^4.1.0",
    "i18next": "^26.0.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^7.15.0"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "chokidar-cli": "^3.0.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^3.2.6"
  },
  "build": {
    "forceCodeSigning": false,
    "appId": "com.mrn.ishtarkati",
    "productName": "Ishtarkati",
    "icon": "build/icon.png",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office",
      "artifactName": "${productName}-${version}-linux.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-win-x64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-win-x64-setup.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.finance",
      "artifactName": "${productName}-${version}-mac-arm64.${ext}",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-arm64.${ext}"
    }
  }
}
