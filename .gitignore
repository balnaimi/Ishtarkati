# Dependencies
node_modules/

# Build & packaging output
dist/
dist-electron/
dist-ssr/
release/

# Local tooling (e.g. vendored Node under .tools/)
.tools/

# Environment & secrets
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test & coverage artifacts
coverage/
.vitest/

# Vite / TypeScript cache
.vite/
*.tsbuildinfo

# Local overrides
*.local

# OS junk
.DS_Store
Thumbs.db
*~

# Editor directories (keep shared recommendations only)
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Cursor IDE — ignore local state; project rules under .cursor/rules/ stay tracked
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# Git hooks are tracked; enable with: git config core.hooksPath .githooks
